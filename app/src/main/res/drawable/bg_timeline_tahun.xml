<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="60dp"
    android:height="28dp"
    android:viewportWidth="100"
    android:viewportHeight="100">
    
    <!-- 
      Mekanisme Jalur (PathData):
      Mulai dari atas (M), tarik garis ke kanan (L), lengkungkan sudut kanan (Q), 
      tarik ke bawah (L), lengkungkan sudut bawah (Q), tarik ke kiri bawah (L), 
      ekstrusi lancip ke tengah kiri (L), lalu tutup jalur (Z).
    -->
    <path
        android:fillColor="#FFFFFF"
        android:strokeColor="#E0E0E0"
        android:strokeWidth="3"
        android:pathData="M 25,5 
                          L 90,5 
                          Q 95,5 95,10 
                          L 95,90 
                          Q 95,95 90,95 
                          L 25,95 
                          L 5,50 
                          Z" />
</vector>
