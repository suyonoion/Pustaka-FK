<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="150dp"
    android:orientation="vertical"
    android:padding="8dp"
    android:layout_margin="4dp"
    android:background="@android:color/white">

    <TextView android:id="@+id/txtGridKategori" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textStyle="bold" android:textColor="#2196F3" />
    <TextView android:id="@+id/txtGridTanggal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="12sp" />
    <TextView android:id="@+id/txtGridCuplikan" android:layout_width="match_parent" android:layout_height="match_parent" android:ellipsize="end" android:maxLines="3" />
</LinearLayout>
