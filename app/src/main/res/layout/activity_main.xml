<androidx.drawerlayout.widget.DrawerLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- KOMPARTEMEN 1: PENAMPANG UTAMA (Wajib dibungkus satu Frame) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Mesin Utama Antarmuka -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="#EFEFEF">
            
            <!-- (Pertahankan seluruh elemen PIPA NAVIGASI ATAS, MULTI-JALUR TIMELINE, hingga FOOTER di sini) -->
        <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:layout_marginBottom="10dp"
    android:layout_marginTop="10dp"
    android:layout_marginStart="8dp">

    <!-- TOMBOL HAMBURGER -->
    <ImageView
        android:id="@+id/btnMenuDrawer"
        android:layout_width="45dp"
        android:layout_height="36dp"
        android:padding="2dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        app:srcCompat="@drawable/ic_hamburger_menu"
        app:tint="#004D40" />

    <!-- KOTAK PENCARIAN -->
       <!-- KOTAK PENCARIAN -->
    <androidx.appcompat.widget.SearchView
    android:id="@+id/edtPencarian"
    android:layout_width="0dp"
    android:layout_height="36dp"
    android:layout_weight="1"
    android:layout_marginStart="2dp"
    android:layout_marginHorizontal="2dp"
    android:paddingVertical="2dp"
    android:paddingHorizontal="2dp"
    android:background="#FFFFFF"
    app:iconifiedByDefault="false"
    app:queryHint="Cari status..."
    android:textSize="12sp"
    android:elevation="2dp"
    android:gravity="center_vertical"
    app:searchIcon="@android:drawable/ic_menu_search"
    app:queryBackground="@android:color/transparent" />
<!-- TOMBOL OPERASIONAL: Filter / Sort Modal -->
    <ImageButton
        android:id="@+id/btnFilterSort"
        android:layout_width="45dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="2dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_filter"
        android:contentDescription="Filter dan Urutkan Status" />
</LinearLayout>

                 <!-- PLAT JUDUL KATEGORI (DOMINAN) -->
         <androidx.cardview.widget.CardView
            android:id="@+id/panelStatusPencarian"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="8dp"
            android:padding="0dp"
            android:layout_margin="0dp"
            app:cardBackgroundColor="#004D40" 
            app:cardCornerRadius="4dp"
            app:cardElevation="2dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp">

                <!-- Teks Dominan Rata Tengah -->
                <TextView
                    android:id="@+id/txtStatusPencarian"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textAlignment="center"
                    android:text="Kategori (0 arsip)" />

                <!-- Sirkuit telemetri lama disembunyikan total dengan atribut yang terdefinisi secara formal -->
               <ProgressBar 
               android:id="@+id/loadingPencarian" 
               android:layout_width="0dp" 
               android:layout_height="0dp" 
               android:visibility="gone"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>


        <!-- WADAH MULTI-JALUR UNTUK GRID DAN TIMELINE -->
        <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:orientation="horizontal">

    <!-- JALUR KIRI: PUSAT PROYEKSI (GRID / BUKU) -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">
        
                <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerGridMode"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingVertical="4dp"
            android:paddingHorizontal="0dp"
            android:clipToPadding="false" />

            
        <RelativeLayout
            android:id="@+id/wadahModeBuku"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/proyektorBuku"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </RelativeLayout>
    </FrameLayout>

    <!-- JALUR KANAN: KANTONG NAVIGASI TIMELINE (DIBERIKAN ID UNTUK KENDALI SENSOR) -->
   <FrameLayout
    android:id="@+id/kontainerJalurKanan"
    android:layout_width="45dp"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:elevation="0dp">
    
    <!-- GARIS PEMBATAS KIRI (SEKAT) -->
    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#D6D6D6" />

    <!-- GARIS TIMELINE UTAMA (MENYATU PENUH DARI ATAS KE BAWAH) -->
    <View
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:layout_gravity="center_horizontal"
        android:background="#80CBC4" />
        
    <!-- RECYCLERVIEW HANYA MENAMPILKAN TITIK / TEKS DI ATAS GARIS -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerTimeline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:scrollbars="none"
        android:paddingTop="0dp"
        android:paddingBottom="0dp"
        android:clipToPadding="false" />
</FrameLayout>

</LinearLayout>

                <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#004D40"
            android:elevation="6dp"
            android:baselineAligned="false">
            
            <LinearLayout
                android:id="@+id/linkSanFK_induk"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_menu_mylocation"
                    app:tint="#FFFFFF"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SanFK"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/linkSaung_induk"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    app:srcCompat="@drawable/logo_saung"
                    app:tint="#FFFFFF"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Saung"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/linkZF_induk"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    app:srcCompat="@drawable/ic_launcher_zf"
                    app:tint="#FFFFFF"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ZF"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

            <!-- INJEKSI TERMINAL BARU: ABOUT -->
            <LinearLayout
                android:id="@+id/menuAbout"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_menu_info_details"
                    app:tint="#FFFFFF"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="About"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>
        </LinearLayout>    
        </LinearLayout>

        <!-- Layar Kaca Pengaman (Letakkan di atas pelat utama) -->
        <include layout="@layout/layout_inisialisasi_mesin" />

    </FrameLayout>

    <!-- KOMPARTEMEN 2: LACI NAVIGASI (Biarkan struktur ini menetap) -->
    <LinearLayout
        android:id="@+id/navViewCustom"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#FAFAFA"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="180dp">

            <!-- 1. GAMBAR VECTOR BACKGROUND (bg_header_drawer.xml) -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/bg_header_drawer" />

            <!-- 2. OVERLAY HITAM TRANSPARAN (Agar teks & foto kontras) -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#80000000" /> 

            <!-- 3. KONTEN FOTO PROFIL DAN TEKS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="bottom"
                android:padding="16dp">

                <com.google.android.material.imageview.ShapeableImageView
    android:id="@+id/fotoProfilAbah"
    android:layout_width="72dp"
    android:layout_height="72dp"
    android:scaleType="centerCrop"
    android:src="@drawable/profil_abah" 
    app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.Users.Circle"
    app:strokeWidth="1.5dp"
    app:strokeColor="#80CBC4" 
    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fatwa Kehidupan"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Arsip Status Digital"
                    android:textColor="#E0E0E0"
                    android:textSize="12sp"/>
            </LinearLayout>

        </FrameLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="10dp">
                
                <!-- Menu Statis Atas -->
                <TextView 
                    android:id="@+id/menuBiografi" 
                    android:layout_width="match_parent" 
                    android:layout_height="wrap_content" 
                    android:text="Biografi" 
                    android:drawableStart="@android:drawable/ic_menu_info_details" 
                    android:drawablePadding="12dp" 
                    android:textColor="#212121" 
                    android:textSize="13sp" 
                    android:paddingVertical="8dp" 
                    android:paddingHorizontal="16dp" 
                    android:background="?android:attr/selectableItemBackground"/>

                <TextView 
                    android:id="@+id/menuSosmed" 
                    android:layout_width="match_parent" 
                    android:layout_height="wrap_content" 
                    android:text="Sosial Media" 
                    android:drawableStart="@android:drawable/ic_menu_share" 
                    android:drawablePadding="12dp" 
                    android:textColor="#212121" 
                    android:textSize="13sp" 
                    android:paddingVertical="8dp" 
                    android:paddingHorizontal="16dp" 
                    android:background="?android:attr/selectableItemBackground"/>

                <TextView 
                    android:id="@+id/menuLetnan" 
                    android:layout_width="match_parent" 
                    android:layout_height="wrap_content" 
                    android:text="Letnan" 
                    android:drawableStart="@android:drawable/ic_menu_myplaces" 
                    android:drawablePadding="12dp" 
                    android:textColor="#212121" 
                    android:textSize="13sp" 
                    android:paddingVertical="8dp" 
                    android:paddingHorizontal="16dp" 
                    android:background="?android:attr/selectableItemBackground"/>
                
                <TextView 
                    android:id="@+id/menuYayasan" 
                    android:layout_width="match_parent" 
                    android:layout_height="wrap_content" 
                    android:text="Yayasan" 
                    android:drawableStart="@android:drawable/ic_menu_manage" 
                    android:drawablePadding="12dp" 
                    android:textColor="#212121" 
                    android:textSize="13sp" 
                    android:paddingVertical="8dp" 
                    android:paddingHorizontal="16dp" 
                    android:background="?android:attr/selectableItemBackground"/>

                <View 
                    android:layout_width="match_parent" 
                    android:layout_height="1dp" 
                    android:background="#E0E0E0" 
                    android:layout_marginVertical="4dp"/>
                
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="KATEGORI STATUS"
                    android:textStyle="bold"
                    android:textColor="#004D40"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:textSize="12sp"/>

                <LinearLayout
                    android:id="@+id/wadahKategoriDinamis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:layout_marginTop="0dp"
                    android:layout_marginBottom="0dp"/>
            </LinearLayout>

        </ScrollView>
    </LinearLayout>
</androidx.drawerlayout.widget.DrawerLayout>