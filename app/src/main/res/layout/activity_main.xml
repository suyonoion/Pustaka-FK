<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#EFEFEF">

        <EditText
            android:id="@+id/edtPencarian"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_margin="10dp"
            android:padding="10dp"
            android:background="@android:color/white"
            android:hint="Cari Fatwa..."
            android:elevation="2dp"
            android:inputType="text"
            android:imeOptions="actionSearch" 
            android:maxLines="1" />

         <androidx.cardview.widget.CardView
            android:id="@+id/panelStatusPencarian"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            android:visibility="gone">

            <!-- WADAH UTAMA CARDVIEW (UBAH MENJADI VERTICAL) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- BARIS 1: INDIKATOR PUTARAN & STATUS UTAMA -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ProgressBar
                        android:id="@+id/loadingPencarian"
                        style="?android:attr/progressBarStyleSmall"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:indeterminateTint="#004D40" />

                    <TextView
                        android:id="@+id/txtStatusPencarian"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:textColor="#1C1E21"
                        android:textSize="13sp"
                        android:text="Memproses data..." />
                </LinearLayout>

                <!-- BARIS 2: SIRKUIT TELEMETRI HORIZONTAL (TAMBAHAN BARU) -->
                <ProgressBar
                    android:id="@+id/pipaVolumeData"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="#004D40"
                    android:visibility="gone" />

                <!-- BARIS 3: TERMINAL OUTPUT DETAIL -->
                <TextView
                    android:id="@+id/txtDetailSubProses"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Menunggu instruksi masuk..."
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:textAlignment="viewEnd"
                    android:visibility="gone" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- WADAH MULTI-JALUR UNTUK GRID DAN TIMELINE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- JALUR KIRI: PUSAT PROYEKSI (GRID / BUKU) -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerGridMode"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="4dp" />
                    
                <RelativeLayout
                    android:id="@+id/wadahModeBuku"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone">
                    <androidx.viewpager2.widget.ViewPager2
                        android:id="@+id/proyektorBuku"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </RelativeLayout>
            </FrameLayout>

            <!-- JALUR KANAN: REL NAVIGASI TIMELINE -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerTimeline"
                android:layout_width="45dp"
                android:layout_height="match_parent"
                android:background="#EFEFEF"
                android:scrollbars="none"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:clipToPadding="false"
                android:elevation="1dp" />
                
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#004D40"
            android:elevation="6dp"
            android:baselineAligned="false">
            <LinearLayout
                android:id="@+id/linkSanFK_induk"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_menu_mylocation"
                    app:tint="#FFFFFF"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SanFK Kendal"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/linkSaung_induk"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    app:srcCompat="@drawable/logo_saung"
                    app:tint="#FFFFFF"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Saung JAWA"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/linkZF_induk"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    app:srcCompat="@drawable/ic_launcher_zf"
                    app:tint="#FFFFFF"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Zuhri Formalism"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navViewCustom"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#FAFAFA"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#004D40"
            android:orientation="vertical"
            android:padding="20dp">
            <ImageView
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@drawable/profil_abah"
                android:scaleType="centerCrop"
                android:layout_marginTop="16dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fatwa Kehidupan"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="12dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Arsip Status Digital"
                android:textColor="#B2DFDB"
                android:textSize="12sp"/>
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="20dp">
                
                <TextView android:id="@+id/menuBiografi" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Biografi" android:drawableStart="@android:drawable/ic_menu_info_details" android:drawablePadding="12dp" android:textColor="#212121" android:textSize="14sp" android:padding="14dp" android:background="?android:attr/selectableItemBackground"/>
                <TextView android:id="@+id/menuSosmed" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Sosial Media" android:drawableStart="@android:drawable/ic_menu_share" android:drawablePadding="12dp" android:textColor="#212121" android:textSize="14sp" android:padding="14dp" android:background="?android:attr/selectableItemBackground"/>
                <TextView android:id="@+id/menuLetnan" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Letnan" android:drawableStart="@android:drawable/ic_menu_myplaces" android:drawablePadding="12dp" android:textColor="#212121" android:textSize="14sp" android:padding="14dp" android:background="?android:attr/selectableItemBackground"/>
                <TextView android:id="@+id/menuYayasan" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Yayasan" android:drawableStart="@android:drawable/ic_menu_manage" android:drawablePadding="12dp" android:textColor="#212121" android:textSize="14sp" android:padding="14dp" android:background="?android:attr/selectableItemBackground"/>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginVertical="8dp"/>
                
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="KATEGORI STATUS"
                    android:textStyle="bold"
                    android:textColor="#004D40"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="10dp"
                    android:textSize="12sp"/>

                <LinearLayout
                    android:id="@+id/wadahKategoriDinamis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</androidx.drawerlayout.widget.DrawerLayout>
