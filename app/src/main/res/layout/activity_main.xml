<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">
      <!-- PIPA PENYAMBUNG ANTARMUKA 7 FASE -->
    <include layout="@layout/layout_inisialisasi_mesin" />
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#EFEFEF">

              <!-- PIPA NAVIGASI ATAS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="10dp"
            android:paddingTop="10dp"
            android:paddingBottom="4dp">
                      <!-- TUAS MEKANIS PEMBUKA LACI -->
            <ImageView
                android:id="@+id/btnMenuDrawer"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_marginStart="8dp"
                android:padding="2dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                app:srcCompat="@android:drawable/ic_menu_sort_by_size"
                app:tint="#004D40" />
            <EditText
                android:id="@+id/edtPencarian"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:padding="10dp"
                android:background="@android:color/white"
                android:hint="Cari Fatwa..."
                android:elevation="2dp"
                android:inputType="text"
                android:imeOptions="actionSearch" 
                android:maxLines="1" />
        </LinearLayout>


                 <!-- PLAT JUDUL KATEGORI (DOMINAN) -->
         <androidx.cardview.widget.CardView
            android:id="@+id/panelStatusPencarian"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="#004D40" 
            app:cardCornerRadius="4dp"
            app:cardElevation="2dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp">

                <!-- Teks Dominan Rata Tengah -->
                <TextView
                    android:id="@+id/txtStatusPencarian"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textAlignment="center"
                    android:text="Kategori (0 arsip)" />

                <!-- Sirkuit telemetri lama disembunyikan total dengan atribut yang terdefinisi secara formal -->
<ProgressBar 
    android:id="@+id/loadingPencarian" 
    android:layout_width="0dp" 
    android:layout_height="0dp" 
    android:visibility="gone"/>

<ProgressBar 
    android:id="@+id/pipaVolumeData" 
    android:layout_width="0dp" 
    android:layout_height="0dp" 
    android:visibility="gone" />

<TextView 
    android:id="@+id/txtDetailSubProses" 
    android:layout_width="0dp" 
    android:layout_height="0dp" 
    android:visibility="gone" />


            </LinearLayout>
        </androidx.cardview.widget.CardView>


        <!-- WADAH MULTI-JALUR UNTUK GRID DAN TIMELINE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- JALUR KIRI: PUSAT PROYEKSI (GRID / BUKU) -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerGridMode"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="4dp" />
                    
                <RelativeLayout
                    android:id="@+id/wadahModeBuku"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone">
                    <androidx.viewpager2.widget.ViewPager2
                        android:id="@+id/proyektorBuku"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </RelativeLayout>
            </FrameLayout>

            <!-- JALUR KANAN: REL NAVIGASI TIMELINE DENGAN GRAVITASI TENGAH -->
            <FrameLayout
                android:layout_width="45dp"
                android:layout_height="match_parent"
                android:background="#EFEFEF"
                android:elevation="1dp">
                
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerTimeline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:scrollbars="none"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:clipToPadding="false" />
            </FrameLayout>

                
        </LinearLayout>

                <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#004D40"
            android:elevation="6dp"
            android:baselineAligned="false">
            
            <LinearLayout
                android:id="@+id/linkSanFK_induk"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_menu_mylocation"
                    app:tint="#FFFFFF"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SanFK"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/linkSaung_induk"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    app:srcCompat="@drawable/logo_saung"
                    app:tint="#FFFFFF"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Saung"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/linkZF_induk"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    app:srcCompat="@drawable/ic_launcher_zf"
                    app:tint="#FFFFFF"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ZF"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

            <!-- INJEKSI TERMINAL BARU: ABOUT -->
            <LinearLayout
                android:id="@+id/menuAbout"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_menu_info_details"
                    app:tint="#FFFFFF"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="About"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/navViewCustom"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#FAFAFA"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#004D40"
            android:orientation="vertical"
            android:padding="20dp">
            <ImageView
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@drawable/profil_abah"
                android:scaleType="centerCrop"
                android:layout_marginTop="16dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fatwa Kehidupan"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="12dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Arsip Status Digital"
                android:textColor="#B2DFDB"
                android:textSize="12sp"/>
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">
                    <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="10dp">
                
                <!-- Pemampatan sumbu Y: paddingVertical diturunkan menjadi 8dp -->
                <TextView android:id="@+id/menuBiografi" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Biografi" android:drawableStart="@android:drawable/ic_menu_info_details" android:drawablePadding="12dp" android:textColor="#212121" android:textSize="14sp" android:paddingVertical="8dp" android:paddingHorizontal="14dp" android:background="?android:attr/selectableItemBackground"/>
                <TextView android:id="@+id/menuSosmed" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Sosial Media" android:drawableStart="@android:drawable/ic_menu_share" android:drawablePadding="12dp" android:textColor="#212121" android:textSize="14sp" android:paddingVertical="8dp" android:paddingHorizontal="14dp" android:background="?android:attr/selectableItemBackground"/>
                <TextView android:id="@+id/menuLetnan" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Letnan" android:drawableStart="@android:drawable/ic_menu_myplaces" android:drawablePadding="12dp" android:textColor="#212121" android:textSize="14sp" android:paddingVertical="8dp" android:paddingHorizontal="14dp" android:background="?android:attr/selectableItemBackground"/>
                <TextView android:id="@+id/menuYayasan" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Yayasan" android:drawableStart="@android:drawable/ic_menu_manage" android:drawablePadding="12dp" android:textColor="#212121" android:textSize="14sp" android:paddingVertical="8dp" android:paddingHorizontal="14dp" android:background="?android:attr/selectableItemBackground"/>

                <!-- Ketebalan garis pembatas diturunkan -->
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginVertical="4dp"/>
                
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="KATEGORI STATUS"
                    android:textStyle="bold"
                    android:textColor="#004D40"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:textSize="12sp"/>

                <!-- Pipa kategori dinamis merapat -->
                <LinearLayout
                    android:id="@+id/wadahKategoriDinamis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp" />
            </LinearLayout>

        </ScrollView>
    </LinearLayout>
</androidx.drawerlayout.widget.DrawerLayout>
