<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/panelInisialisasiUtama"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#004D40"
    android:elevation="10dp">

    <!-- SEKTOR RANTAI KOMANDO (Daftar 7 Fase) -->
    <!-- Menggunakan ScrollView jika layar vertikal (ponsel), 
         untuk memastikan seluruh modul mesin terlihat -->
    <LinearLayout
        android:id="@+id/kompartemenFase"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Contoh Baris 1: Status Fase -->
        <TextView
            android:id="@+id/teksStatusFase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>

    <!-- SEKTOR REAKTOR UTAMA (Visual & Persentase) -->
    <ImageView
        android:id="@+id/indikatorVisualMesin"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:src="@drawable/img_1"
        app:layout_constraintTop_toBottomOf="@id/kompartemenFase"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"/>

    <!-- Indikator Lingkar Sentral -->
    <ProgressBar
        android:id="@+id/lingkarPersentaseUtama"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:progressDrawable="@drawable/desain_lingkar_progres"
        android:max="100"
        android:progress="0"
        app:layout_constraintTop_toBottomOf="@id/indikatorVisualMesin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"/>

    <TextView
        android:id="@+id/teksPersentaseSentral"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0%"
        android:textColor="#00E5FF"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/lingkarPersentaseUtama"
        app:layout_constraintBottom_toBottomOf="@id/lingkarPersentaseUtama"
        app:layout_constraintStart_toStartOf="@id/lingkarPersentaseUtama"
        app:layout_constraintEnd_toEndOf="@id/lingkarPersentaseUtama"/>

    <!-- Telemetri Volume Data -->
    <TextView
        android:id="@+id/teksTelemetriData"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="PUSTAKA FK \n Arsip Status Digital Fatwa Kehidupan"
        android:textColor="#8892B0"
        android:textSize="14sp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/lingkarPersentaseUtama"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
