<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA" 
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="12dp">
        <ImageView
            android:id="@+id/imgProfilAbah"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:src="@drawable/profil_abah"
            android:scaleType="centerCrop"/>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Syeikh Muhammad Zuhri"
                android:textColor="#004D40"
                android:textSize="15sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fatwa Kehidupan"
                android:textColor="#00B0FF"
                android:textSize="12sp" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/txtTanggal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tanggal"
                    android:textSize="10sp"
                    android:textColor="#424242"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • "
                    android:textSize="10sp"/>
                <TextView
                    android:id="@+id/txtKategori"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kategori"
                    android:textColor="#D32F2F"
                    android:textStyle="bold"
                    android:textSize="10sp"/>
            </LinearLayout>
        </LinearLayout>
        <TextView
            android:id="@+id/txtNomorHalaman"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hal: -/-"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#004D40"
            android:background="#E0F2F1"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginBottom="12dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            
            <!-- TEKS ASLI PEMOSTING UTAMA ("Mantap... DJ nya...") -->
            <TextView
                android:id="@+id/txtKontenUtama"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#212121"
                android:lineSpacingExtra="5dp"
                android:autoLink="web"
                android:linksClickable="true"
                android:textColorLink="#00B0FF"
                android:layout_marginBottom="10dp"/>

            <!-- WADAH DINAMIS (Merangkum Teks Shared + Foto/Video) -->
            <LinearLayout
                android:id="@+id/wadahDinamisKonten"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">
                
                <!-- HEADER SHARED POST (Logo & Nama) -->
                <LinearLayout
                    android:id="@+id/wadahHeaderShared"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp"
                    android:visibility="gone">
                                        <ImageView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        app:tint="#9E9E9E"
                        android:scaleType="centerInside"
                        android:background="#EAEAEA"
                        android:padding="6dp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="10dp">
                        <TextView
                            android:id="@+id/txtNamaPemilikShared"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#1C1E21"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Status Dibagikan"
                            android:textColor="#65676B"
                            android:textSize="11sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- TEKS SHARED POST ("Assalamu'alaikum...") -->
                <TextView
                    android:id="@+id/txtKontenShared"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#1C1E21"
                    android:lineSpacingExtra="4dp"
                    android:autoLink="web"
                    android:linksClickable="true"
                    android:textColorLink="#00B0FF"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"/>

                <!-- PROYEKTOR MEDIA (Selalu berada di bagian paling bawah teks) -->
                <LinearLayout
                    android:id="@+id/wadahMultiFoto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:id="@+id/linkSumberTautan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="?android:attr/selectableItemBackground"
                    android:padding="6dp">
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" app:srcCompat="@drawable/logo_fb"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sumber Asli" android:textColor="#1976D2" android:textSize="12sp" android:textStyle="bold" android:layout_marginStart="8dp"/>
                </LinearLayout>
                <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
                <LinearLayout
                    android:id="@+id/btnBagikanKonten"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="?android:attr/selectableItemBackground"
                    android:padding="6dp">
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@android:drawable/ic_menu_share" app:tint="#424242"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bagikan" android:textColor="#424242" android:textSize="12sp" android:textStyle="bold" android:layout_marginStart="8dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
